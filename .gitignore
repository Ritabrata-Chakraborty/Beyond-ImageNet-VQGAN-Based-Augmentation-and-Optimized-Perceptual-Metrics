# Experiments: keep structure and scripts; ignore checkpoints, plots, CSVs
experiments/**/checkpoints/
experiments/**/*.csv
experiments/**/plots/
experiments/**/*.png
experiments/**/*.pdf
experiments/**/*.pth
experiments/**/*.pt
experiments/generative/
experiments/classification/
experiments/perceptual/checkpoints/

# Docs and compiled readmes
docs/
COMPILED_READMES.md

# Keep scripts and small configs under experiments
!experiments/**/*.sh
!experiments/**/*.md
!experiments/**/*.yml
!experiments/**/*.yaml

# Root-level checkpoints and runs
checkpoints/
*.pth
*.pt

